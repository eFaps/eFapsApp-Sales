  <query language="eFaps"><![CDATA[print obj $P!{INSTANCE}
 select
 attribute[Name] as name,
 attribute[Date] as date,
 attribute[Note] as note,
 attribute[RateCrossTotal] as rateCrossTotal,
 attribute[RateNetTotal] as rateNetTotal,
